MAIN := IPleiriaMain
LATEXMK := latexmk
LATEXMK_FLAGS := -xelatex -shell-escape -interaction=nonstopmode -file-line-error

# Temporary files generated by LaTeX/Biber/latexmk
LATEX_TMP_EXT := \
	aux bbl bcf blg fdb_latexmk fls glg glo gls ist lof log lot out run.xml synctex.gz toc xdv lol

# Optional build artefacts
LATEX_BUILD_EXT := pdf

.PHONY: help all build rebuild clean distclean

all: build

help:
	@echo "Targets disponibles :"
	@echo "  make build     -> compile le rapport PDF"
	@echo "  make rebuild   -> clean complet puis compilation"
	@echo "  make           -> alias de make build"
	@echo "  make clean     -> supprime les fichiers temporaires de compilation"
	@echo "  make distclean -> supprime aussi le PDF final"

build:
	@echo "[build] Compilation du rapport..."
	@$(LATEXMK) $(LATEXMK_FLAGS) $(MAIN).tex
	@$(MAKE) clean
	@echo "[build] PDF généré : $(MAIN).pdf"

rebuild: distclean build

clean:
	@echo "[clean] Suppression des fichiers temporaires..."
	@for ext in $(LATEX_TMP_EXT); do \
		rm -f $(MAIN).$$ext; \
	done
	@find . -type f \( \
		-name "*.aux" -o -name "*.bbl" -o -name "*.bcf" -o -name "*.blg" -o -name "*.fdb_latexmk" -o -name "*.fls" -o -name "*.glg" -o -name "*.glo" -o -name "*.gls" -o -name "*.ist" -o -name "*.lof" -o -name "*.log" -o -name "*.lot" -o -name "*.out" -o -name "*.run.xml" -o -name "*.synctex.gz" -o -name "*.toc" -o -name "*.xdv" -o -name "*.lol" \
	\) -delete
	@echo "[clean] Terminé."

distclean: clean
	@echo "[distclean] Suppression du PDF..."
	@for ext in $(LATEX_BUILD_EXT); do \
		rm -f $(MAIN).$$ext; \
	done
	@echo "[distclean] Terminé."
